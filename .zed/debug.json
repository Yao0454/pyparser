// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "Debug C++",
    "adapter": "CodeLLDB",
    "request": "launch",
    "program": "$ZED_WORKTREE_ROOT/$ZED_STEM.out",
    "cwd": "$ZED_WORKTREE_ROOT",
    "build": {
      "command": "clang++",
      "args": ["-g", "$ZED_FILE", "-o", "$ZED_STEM.out", "-Wall", "-Wextra"],
    },
  },
]
